<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 获得焦点或激活状态：蓝色 -->
    <item android:color="#1976D2" android:state_focused="true" />
    <item android:color="#1976D2" android:state_activated="true" />
    <!-- 默认状态（未激活）：灰色 -->
    <item android:color="#C3C3C3" />
</selector>